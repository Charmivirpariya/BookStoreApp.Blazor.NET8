@page "/books/index"
@using Microsoft.AspNetCore.Components.Authorization
@inject IBookService bookService
@inject IJSRuntime jsRuntime
<h3>Book Page</h3>
@if (response.Success == false)
{
    <div class="alert alert-danger">
        <h7>@response.Message</h7>
    </div>
}

@if (Books == null)
{
    <div class="alert alert-info">
        <h7>Loading Data...</h7>
    </div>
}
else
{
    <AuthorizeView Roles="Administrator">
        <a class="btn btn-dark" href="/books/create">
            <span class="bi bi-plus" aria-hidden="true"></span>
            Create
        </a>
    </AuthorizeView>
    <br />
    <table class="table  table-responsive">
        <thead>
            <tr>
                <th></th>
                <th>Title</th>
                <th>Price</th>
                <th>Author Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Books)
            {
                <tr>
                    <td><img src="@book.Image" alt="@book.Title" class="img-thumbnail" style="width: 100px; height: 150px;" /></td>
                    <td>@book.Title</td>
                    <td>@book.Price.ToString("C")</td>
                    <td>
                        <a href="/authors/details/@book.AuthorId"
                           class="text-decoration-none">
                            @book.AuthorName
                        </a>
                    </td>
                    <td>

                        <a class="btn btn-outline-primary" href="/books/details/@book.Id"><span class="bi bi-book" aria-hidden="true"></span> Details</a>

                        <AuthorizeView Roles="Administrator">
                            <a class="btn btn-outline-secondary" href="/books/update/@book.Id"><span class="bi bi-pencil" aria-hidden="true"></span> Edit</a>
                            <button class="btn btn-outline-danger" @onclick=@(() => Delete(@book.Id))>
                                <span class="bi bi-trash" aria-hidden="true"></span>Delete
                            </button>
                        </AuthorizeView>

                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<BookReadOnlyDto> Books;
    private Response<List<BookReadOnlyDto>> response = new Response<List<BookReadOnlyDto>> { Success = true };

    protected override async Task OnInitializedAsync()
    {
        var response = await bookService.GetBooks();
        if (response.Success)
        {
            Books = response.Data;
        }

    }
    private async Task Delete(int bookId)
    {
        var bookTitle = Books.FirstOrDefault(b => b.Id == bookId)?.Title;

        var confirm = await jsRuntime.InvokeAsync<bool>(
            "confirm",
            $"Are you sure you want to delete the book '{bookTitle}'?"
        );

        if (confirm)
        {
            var response = await bookService.Delete(bookId);

            if (response.Success)
            {
                await OnInitializedAsync();
            }
        }
    }
}
