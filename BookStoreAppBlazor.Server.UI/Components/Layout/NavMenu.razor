@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">BookStoreAppBlazor.Server.UI</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">

        <AuthorizeView Context="authState">

            <Authorized>

                <div class="nav-item px-3">
                    <span class="nav-link text-white">
                        <span class="bi bi-person-fill fs-5 mb-4 " aria-hidden="true"></span>
                        @authState.User.Identity?.Name
                    </span>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>
                        Home
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="authors/index">
                        <span class="bi bi-book fs-5 mb-4"></span>
                        Authors
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="books/index">
                        <span class="bi bi-journal fs-5 mb-4"></span>
                        Books
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="users/logout">
                        <span class="bi bi-box-arrow-right fs-5 mb-4"></span>
                        Logout
                    </NavLink>
                </div>
                
            </Authorized>

            <NotAuthorized>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="users/login">
                        <span class="bi bi-box-arrow-in-right fs-5 mb-4"></span>
                        Login
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="users/register">
                        <span class="bi bi-person-plus-fill fs-5 mb-4"></span>
                        Register
                    </NavLink>
                </div>

            </NotAuthorized>
           
        </AuthorizeView>

    </nav>
</div>