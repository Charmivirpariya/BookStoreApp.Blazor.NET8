{
  "ConnectionStrings": {
    "BookStoreAppDbConnection": "Server=(localdb)\\mssqllocaldb;Database=BookStoreDb;Trusted_Connection=true;MultipleActiveResultSets=true",
    "BookStoreDbContext": "Server=(localdb)\\mssqllocaldb;Database=BookStoreDbContext;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "JwtSettings": {
    "Key": "5fe86d48-8b3a-4645-a5e3-3d43e697e0a0",
    "Issuer": "BookStoreAPI",
    "Audience": "BookStoreApiClient",
    "DurationInHours": 1

  },
  "AllowedHosts": "*"
}